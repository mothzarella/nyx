root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# the right syntax rule
[*.nix,*.toml,*.yml,*.sh,*.md]
indent_size = 2
indent_style = space

# the one shfmt understands
[*.sh]
indent_size = 2
indent_style = space

# the one Zed understands
[**.nix,**.toml,**.yml,**.sh,**.md]
indent_size = 2
indent_style = space
